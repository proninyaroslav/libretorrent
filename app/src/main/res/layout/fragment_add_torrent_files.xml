<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="org.proninyaroslav.libretorrent.ui.addtorrent.AddTorrentViewModel" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator_layout"
        style="@style/ThemeOverlay.App.Surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/status_string"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_marginHorizontal="20dp"
                android:visibility="@{viewModel.info.fileCount == 0 ? View.GONE : View.VISIBLE}">

                <ImageView
                    android:id="@+id/status_icon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/ic_checklist_24px" />

                <TextView
                    android:id="@+id/files_size"
                    style="?attr/textAppearanceLabelMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    app:layout_constraintBottom_toTopOf="@id/free_space"
                    app:layout_constraintEnd_toStartOf="@id/toggle_row"
                    app:layout_constraintStart_toEndOf="@id/status_icon"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="1 Mb of 1Mb selected" />

                <TextView
                    android:id="@+id/free_space"
                    style="?attr/textAppearanceLabelSmall"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="16dp"
                    app:fileSize="@{viewModel.mutableParams.storageFreeSpace}"
                    app:formatFileSize="@{@string/free_space}"
                    app:layout_constraintBottom_toTopOf="@id/status_divider"
                    app:layout_constraintEnd_toStartOf="@id/toggle_row"
                    app:layout_constraintStart_toEndOf="@id/status_icon"
                    tools:text="100 GB free" />

                <LinearLayout
                    android:id="@+id/toggle_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toTopOf="@id/status_divider"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <Button
                        android:id="@+id/search_toggle_button"
                        style="?attr/materialIconButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/search"
                        app:icon="@drawable/ic_search_24px" />

                    <Button
                        android:id="@+id/filter_toggle_button"
                        style="?attr/materialIconButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/filter"
                        app:icon="@drawable/ic_tune_24px" />
                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:id="@+id/status_divider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/search_sort_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/status_string"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="@{viewModel.info.fileCount == 0 ? View.GONE : View.VISIBLE}">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/search_input_layout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/search"
                    android:visibility="gone"
                    app:startIconDrawable="@drawable/ic_close_24px"
                    tools:visibility="visible">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/search_edit_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <RelativeLayout
                    android:id="@+id/sort_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/sort_chip_group"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/sort_direction_toggle_button"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/sort_by_name"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checkable="true"
                            android:checked="true"
                            android:text="@string/drawer_sorting_name" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/sort_by_size"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checkable="true"
                            android:text="@string/drawer_sorting_size" />
                    </com.google.android.material.chip.ChipGroup>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/sort_direction_toggle_button"
                        style="@style/Widget.Material3.MaterialButtonGroup.Connected"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        app:checkedButton="@id/sort_asc_button"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <Button
                            android:id="@+id/sort_asc_button"
                            style="?attr/materialIconButtonFilledTonalStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/ascending_sort"
                            app:icon="@drawable/ic_sort_24px" />

                        <Button
                            android:id="@+id/sort_desc_button"
                            style="?attr/materialIconButtonFilledTonalStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/descending_sort"
                            app:icon="@drawable/ic_sort_desc_24px" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </RelativeLayout>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/file_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/search_sort_bar"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="@dimen/bottom_bar_padding"
                android:scrollbars="vertical"
                android:visibility="@{viewModel.info.fileCount == 0 ? View.GONE : View.VISIBLE}"
                tools:itemCount="3"
                tools:listitem="@layout/item_torrent_downloadable_file" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="?attr/actionBarSize"
                android:visibility="@{viewModel.info.fileCount == 0 ? View.VISIBLE : View.GONE}"
                tools:visibility="gone">

                <include layout="@layout/list_load_indicator" />
            </RelativeLayout>
        </RelativeLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>